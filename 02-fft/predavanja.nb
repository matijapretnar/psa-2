   RowBox[{"koeficienti_", ",", "x_"}], "]"}], ":=", 
  RowBox[{"Fold", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", "acc"}], "}"}], "|->", 
      RowBox[{
       RowBox[{"a", " ", "x"}], "+", "acc"}]}], ")"}], ",", 
    RowBox[{"Reverse", "[", "koeficienti", "]"}]}], "]"}]}]], "Input",
