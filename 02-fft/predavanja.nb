Cell[TextData[{
 "Obratno lahko uporabimo Lagrangeovo interpolacijo ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubsuperscriptBox["\[Sum]", 
     RowBox[{"i", "=", "0"}], "n"], 
    RowBox[{
     SubscriptBox["y", "i"], 
     FractionBox[
      RowBox[{
       SubscriptBox["\[Product]", 
        RowBox[{"j", "!=", "i"}]], 
       RowBox[{"(", 
        RowBox[{"x", "-", 
         SubscriptBox["x", "j"]}], ")"}]}], 
      RowBox[{
       SubscriptBox["\[Product]", 
        RowBox[{"j", "!=", "i"}]], 
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["x", "i"], "-", 
         SubscriptBox["x", "j"]}], ")"}]}]]}]}], TraditionalForm]],
  ExpressionUUID->"734b580f-69b7-4309-83d6-2e8924b31948"],
 ":"
}], "Text",
 CellChangeTimes->{{3.982292707606942*^9, 3.982292717459772*^9}, {
  3.982292772501544*^9, 3.9822927915248327`*^9}, {3.982292845676983*^9, 
  3.9822928595655937`*^9}, {3.9822929713500032`*^9, 3.982292974086001*^9}, {
  3.982293144342763*^9, 3.982293146344493*^9}, {3.982293344641296*^9, 
  3.982293415245414*^9}, {3.982293452625887*^9, 3.98229353415475*^9}, {
  3.982294648281279*^9, 3.9822947667308083`*^9}, {3.9822950355338917`*^9, 
  3.982295043729948*^9}},ExpressionUUID->"34d7cc16-7633-44cd-960c-\
9e8795962560"],

Cell[BoxData[
 RowBox[{
  RowBox[{"interpoliraj", "[", 
   RowBox[{"tocke_", ",", "vrednosti_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"N", "=", 
      RowBox[{"Length", "[", "tocke", "]"}]}], "}"}], ",", 
    "\[IndentingNewLine]", 
    RowBox[{"x", "|->", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"i", "=", "1"}], "N"], 
      RowBox[{
       RowBox[{"vrednosti", "[", 
        RowBox[{"[", "i", "]"}], "]"}], " ", 
       RowBox[{
        SubsuperscriptBox["\[Product]", 
         RowBox[{"j", "=", "1"}], "N"], 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"i", "!=", "j"}], ",", 
          FractionBox[
           RowBox[{"x", "-", 
            RowBox[{"tocke", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}], 
           RowBox[{
            RowBox[{"tocke", "[", 
             RowBox[{"[", "i", "]"}], "]"}], "-", 
            RowBox[{"tocke", "[", 
             RowBox[{"[", "j", "]"}], "]"}]}]], ",", "1"}], "]"}]}]}]}]}]}], 
   "\[IndentingNewLine]", "]"}]}]], "Input",
 CellChangeTimes->{{3.982294263636313*^9, 3.982294373152088*^9}, {
  3.982294437741658*^9, 3.9822944521272373`*^9}, {3.982294498668398*^9, 
  3.982294582113764*^9}, {3.982294956484429*^9, 3.982295030481104*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"ef3d472e-2e46-4045-b8cf-42b09507f5a6"],

