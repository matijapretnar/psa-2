     RowBox[{"M", "=", 
      RowBox[{"N", "/", "r"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"kosi", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"fft", "[", 
         RowBox[{
          RowBox[{"koeficienti", "[", 
           RowBox[{"[", 
            RowBox[{"j", ";;", "N", ";;", "r"}], "]"}], "]"}], ",", 
          RowBox[{"{", "rs", "}"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "r"}], "}"}]}], "]"}]}], ";", 
