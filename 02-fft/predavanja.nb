Cell[CellGroupData[{

Cell["Posplo\[SHacek]itve FFT", "Chapter",
 CellChangeTimes->{{3.982292691475251*^9, 3.9822926944570103`*^9}, {
  3.9829448481145887`*^9, 
  3.982944851040629*^9}},ExpressionUUID->"1e93833c-831c-467a-9948-\
ae2fc44707a8"],

Cell[CellGroupData[{

Cell["Kon\[CHacek]ni obsegi", "Section",
 CellChangeTimes->{{3.982292700586426*^9, 3.982292706269356*^9}, {
  3.982944859556201*^9, 
  3.9829448614221163`*^9}},ExpressionUUID->"a5e4e178-6546-46c8-bc93-\
9e3d260fe8e1"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ntt", "[", 
   RowBox[{
    RowBox[{"{", "x_", "}"}], ",", "_"}], "]"}], ":=", 
  RowBox[{"{", "x", "}"}]}], "\n", 
 RowBox[{
  RowBox[{"ntt", "[", 
   RowBox[{"koeficienti_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"N", "=", 
       RowBox[{"Length", "[", "koeficienti", "]"}]}], ",", "sodi", ",", 
      "lihi", ",", "w", ",", "prckanje"}], "}"}], ",", "\[IndentingNewLine]", 
    
    RowBox[{
     RowBox[{"sodi", "=", 
      RowBox[{"ntt", "[", 
       RowBox[{
        RowBox[{"koeficienti", "[", 
         RowBox[{"[", 
          RowBox[{"1", ";;", "N", ";;", "2"}], "]"}], "]"}], ",", "p"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"lihi", "=", 
      RowBox[{"ntt", "[", 
       RowBox[{
        RowBox[{"koeficienti", "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", "N", ";;", "2"}], "]"}], "]"}], ",", "p"}], 
       "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"w", "=", 
      RowBox[{"PowerMod", "[", 
       RowBox[{
        RowBox[{"PrimitiveRoot", "[", "p", "]"}], ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"p", "-", "1"}], ")"}], "/", "N"}], ",", "p"}], "]"}]}], ";",
      "\[IndentingNewLine]", 
     RowBox[{"prckanje", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"PowerMod", "[", 
         RowBox[{"w", ",", "k", ",", "p"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", 
          RowBox[{
           RowBox[{"N", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"sodi", "+", 
        RowBox[{"prckanje", " ", "lihi"}]}], ",", 
       RowBox[{"sodi", "-", 
        RowBox[{"prckanje", " ", "lihi"}]}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.9829879403593817`*^9, 3.982988020715249*^9}, {
  3.9829880582992496`*^9, 3.982988065239037*^9}, {3.982988283336907*^9, 
  3.982988292421012*^9}, {3.982988852591194*^9, 3.982988854973136*^9}, {
  3.98298889793434*^9, 3.9829888998722982`*^9}, {3.9829889498978863`*^9, 
  3.982988950199072*^9}, {3.982989053892384*^9, 3.98298906027801*^9}, {
