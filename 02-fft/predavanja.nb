  3.982295833797565*^9, 3.982295858407617*^9}},
 CellLabel->"In[15]:=",ExpressionUUID->"63e158ce-7b32-4871-a184-f529958bfdc5"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", 
   SuperscriptBox["\[ExponentialE]", 
    FractionBox[
     RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]], ",", "\[ImaginaryI]", ",", 
   SuperscriptBox["\[ExponentialE]", 
    FractionBox[
     RowBox[{"3", " ", "\[ImaginaryI]", " ", "\[Pi]"}], "4"]], ",", 
   RowBox[{"-", "1"}], ",", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"3", " ", "\[ImaginaryI]", " ", "\[Pi]"}], "4"]}]], ",", 
   RowBox[{"-", "\[ImaginaryI]"}], ",", 
   SuperscriptBox["\[ExponentialE]", 
    RowBox[{"-", 
     FractionBox[
      RowBox[{"\[ImaginaryI]", " ", "\[Pi]"}], "4"]}]]}], "}"}]], "Output",
 CellChangeTimes->{{3.98229584879403*^9, 3.9822958588581667`*^9}, 
