Cell[CellGroupData[{

Cell["Inverz hitre Fourierove transformacije", "Section",
 CellChangeTimes->{{3.982292700586426*^9, 3.982292706269356*^9}, {
  3.9822947937790728`*^9, 3.982294804471773*^9}, {3.982295917795383*^9, 
  3.982295925041238*^9}},ExpressionUUID->"700f9ae0-e036-4a4b-bd48-\
4b2eba6f695e"],

Cell[TextData[{
 "Fourierovo transformacijo lahko zapi\[SHacek]emo tudi v matri\[CHacek]ni \
obliki:\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"FFT", "(", GridBox[{
       {
        SubscriptBox["a", "0"]},
       {
        SubscriptBox["a", "1"]},
       {"\[VerticalEllipsis]"},
       {
        SubscriptBox["a", "n"]}
      }], ")"}], "=", 
    RowBox[{
     RowBox[{"(", GridBox[{
        {
         RowBox[{
          RowBox[{"p", "(", 
           SuperscriptBox["\[Omega]", "0"], ")"}], "=", 
          RowBox[{
           SubscriptBox["a", "0"], "+", 
           RowBox[{
            SubscriptBox["a", "1"], "\[Omega]"}], "+", "\[CenterEllipsis]", "+", 
           RowBox[{
            SubscriptBox["a", "n"], 
            SuperscriptBox["\[Omega]", "n"]}]}]}]},
        {
         RowBox[{
          RowBox[{"p", "(", 
           SuperscriptBox["\[Omega]", "2"], ")"}], "=", 
          RowBox[{
           SubscriptBox["a", "0"], "+", 
           RowBox[{
            SubscriptBox["a", "1"], 
            SuperscriptBox["\[Omega]", "2"]}], "+", "\[CenterEllipsis]", "+", 
           
           RowBox[{
            SubscriptBox["a", "n"], 
            SuperscriptBox["\[Omega]", 
             RowBox[{"2", "n"}]]}]}]}]},
        {"\[VerticalEllipsis]"},
        {
         RowBox[{
          RowBox[{"p", "(", 
           SuperscriptBox["\[Omega]", "n"], ")"}], "=", 
          RowBox[{
           SubscriptBox["a", "0"], "+", 
           RowBox[{
            SubscriptBox["a", "1"], 
            SuperscriptBox["\[Omega]", "n"]}], "+", "\[CenterEllipsis]", "+", 
           
           RowBox[{
            SubscriptBox["a", "n"], 
            SuperscriptBox["\[Omega]", 
             SuperscriptBox["n", "2"]]}]}]}]}
       }], ")"}], "=", 
     RowBox[{
      RowBox[{"(", GridBox[{
         {"1", "1", "\[CenterEllipsis]", "1"},
         {"1", "\[Omega]", "\[CenterEllipsis]", 
          SuperscriptBox["\[Omega]", "n"]},
         {"\[VerticalEllipsis]", "\[VerticalEllipsis]", 
          "\[DescendingEllipsis]", "\[VerticalEllipsis]"},
         {"1", 
          SuperscriptBox["\[Omega]", "n"], "\[CenterEllipsis]", 
          SuperscriptBox["\[Omega]", 
           SuperscriptBox["n", "2"]]}
        }], ")"}], 
      RowBox[{"(", GridBox[{
         {
          SubscriptBox["a", "0"]},
         {
          SubscriptBox["a", "1"]},
         {"\[VerticalEllipsis]"},
         {
          SubscriptBox["a", "n"]}
        }], ")"}]}]}]}], TraditionalForm]],ExpressionUUID->
  "6b381ee1-5e7f-4d49-bcc9-455774ec4cda"],
 " = W",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {
       SubscriptBox["a", "0"]},
      {
       SubscriptBox["a", "1"]},
      {"\[VerticalEllipsis]"},
      {
       SubscriptBox["a", "n"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "c768e02e-82db-4288-b871-9d43700b0fe8"],
 "\nTorej za interpolacijo lahko uporabimo kar inverz matrike ",
 Cell[BoxData[
  FormBox["W", TraditionalForm]],ExpressionUUID->
  "f2219fb2-c579-42c1-8521-b5f7b2fe8e99"],
 ". \[CapitalCHacek]e preverimo:\n",
 Cell[BoxData[
  FormBox[
   RowBox[{"W", " ", 
    OverscriptBox["W", "_"]}], TraditionalForm]],ExpressionUUID->
  "2d43213c-f055-424c-81d1-a393287ee5a5"],
 " = ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"1", "1", "\[CenterEllipsis]", "1"},
      {"1", "\[Omega]", "\[CenterEllipsis]", 
       SuperscriptBox["\[Omega]", "n"]},
      {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
       "\[VerticalEllipsis]"},
      {"1", 
       SuperscriptBox["\[Omega]", "n"], "\[CenterEllipsis]", 
       SuperscriptBox["\[Omega]", 
        SuperscriptBox["n", "2"]]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "33e65ade-3e86-4239-aca4-a6b44ba6a051"],
 Cell[BoxData[
  FormBox[
   RowBox[{"(", GridBox[{
      {"1", "1", "\[CenterEllipsis]", "1"},
      {"1", 
       OverscriptBox["\[Omega]", "_"], "\[CenterEllipsis]", 
       OverscriptBox[
        SuperscriptBox["\[Omega]", "n"], "_"]},
      {"\[VerticalEllipsis]", "\[VerticalEllipsis]", "\[DescendingEllipsis]", 
       "\[VerticalEllipsis]"},
      {"1", 
       OverscriptBox[
        SuperscriptBox["\[Omega]", "n"], "_"], "\[CenterEllipsis]", 
       OverscriptBox[
        SuperscriptBox["\[Omega]", 
         SuperscriptBox["n", "2"]], "_"]}
     }], ")"}], TraditionalForm]],ExpressionUUID->
  "d6dac04f-2680-4ec1-9560-d023ab1a639b"],
 "\noziroma\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{"W", " ", 
       OverscriptBox["W", "_"]}], ")"}], 
     RowBox[{"i", " ", "j"}]], "=", 
    RowBox[{
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "0"}], "n"], 
      RowBox[{
       SuperscriptBox["\[Omega]", 
        RowBox[{"i", " ", "k"}]], 
       SuperscriptBox[
        OverscriptBox["\[Omega]", "_"], 
        RowBox[{"k", " ", "j"}]]}]}], "=", 
     RowBox[{
      SubsuperscriptBox["\[Sum]", 
       RowBox[{"k", "=", "0"}], "n"], 
      SuperscriptBox["\[Omega]", 
       RowBox[{
        RowBox[{"(", 
         RowBox[{"i", "-", "j"}], ")"}], "k"}]]}]}]}], TraditionalForm]],
  ExpressionUUID->"e11585eb-b475-4ac1-b6cd-e7ca32771234"],
 "\n\[CapitalCHacek]e je ",
 Cell[BoxData[
  FormBox[
   RowBox[{"i", "=", "j"}], TraditionalForm]],ExpressionUUID->
  "a9894264-784c-47b6-989c-7f8994b68fb5"],
 ", so vsi \[CHacek]leni enaki ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],ExpressionUUID->
  "7eab16f8-6be6-4461-9e31-9a3d0576ff0d"],
 ", zato je ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox[
     RowBox[{"(", 
      RowBox[{"W", " ", 
       OverscriptBox["W", "_"]}], ")"}], 
     RowBox[{"i", " ", "j"}]], "=", 
    RowBox[{
     RowBox[{"n", "+", "1"}], "=", "N"}]}], TraditionalForm]],ExpressionUUID->
  "3e560085-c0c3-4757-9ca9-a896847f7b2c"],
 ", sicer pa imamo geometrijsko vrsto\n",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{
     SubsuperscriptBox["\[Sum]", 
      RowBox[{"k", "=", "0"}], "n"], 
     SuperscriptBox["\[Omega]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"i", "-", "j"}], ")"}], "k"}]]}], "=", 
    RowBox[{
     SuperscriptBox["\[Omega]", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"i", "-", "j"}], ")"}], "N"}]], "=", "0"}]}], 
   TraditionalForm]],ExpressionUUID->"3ca0b4e3-1c7e-4a51-8aaf-20fe48ab4dd8"],
 "\nzato je ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"W", " ", 
     OverscriptBox["W", "_"]}], "=", 
    RowBox[{"N", " ", "I"}]}], TraditionalForm]],ExpressionUUID->
  "74765884-170b-43c0-8227-c3c83edc7692"],
 " oziroma ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["W", 
     RowBox[{"-", "1"}]], "=", 
    RowBox[{
     FractionBox["1", "N"], 
     OverscriptBox["W", "_"]}]}], TraditionalForm]],ExpressionUUID->
  "e4b85cb7-9b1b-40bb-8b1a-b19e35942f87"],
 ". Inverz lahko torej u\[CHacek]inkovito izra\[CHacek]unamo na podoben na\
\[CHacek]in:"
}], "Text",
 CellChangeTimes->{{3.982292707606942*^9, 3.982292717459772*^9}, {
  3.982292772501544*^9, 3.9822927915248327`*^9}, {3.982292845676983*^9, 
  3.9822928595655937`*^9}, {3.9822929713500032`*^9, 3.982292974086001*^9}, {
  3.982293144342763*^9, 3.982293146344493*^9}, {3.982293344641296*^9, 
  3.982293415245414*^9}, {3.982293452625887*^9, 3.98229353415475*^9}, {
  3.982294648281279*^9, 3.9822947667308083`*^9}, {3.9822948135293016`*^9, 
  3.982294883529632*^9}, {3.982295053860841*^9, 3.98229552708777*^9}, {
  3.982295621184682*^9, 3.9822956287501717`*^9}, {3.9822959886170053`*^9, 
  3.982296455037684*^9}, {3.982296485441094*^9, 3.9822965624028883`*^9}, {
  3.98229659301054*^9, 3.982297080959751*^9}, {3.982297423709532*^9, 
  3.9822974292938623`*^9}},ExpressionUUID->"1a96546b-a95a-43c5-867b-\
2d56a5ade185"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"ifft", "[", 
   RowBox[{"{", "x_", "}"}], "]"}], ":=", 
  RowBox[{"{", "x", "}"}]}], "\n", 
 RowBox[{
  RowBox[{"ifft", "[", "koeficienti_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"N", "=", 
        RowBox[{"Length", "[", "koeficienti", "]"}]}], ",", "sodi", ",", 
       "lihi", ",", "w", ",", "prckanje"}], "}"}], ",", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"sodi", "=", 
       RowBox[{"ifft", "[", 
        RowBox[{"koeficienti", "[", 
         RowBox[{"[", 
          RowBox[{"1", ";;", "N", ";;", "2"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"lihi", "=", 
       RowBox[{"ifft", "[", 
        RowBox[{"koeficienti", "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", "N", ";;", "2"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"w", "=", 
       SuperscriptBox["\[ExponentialE]", 
        RowBox[{"2", "\[Pi]", " ", 
         RowBox[{"\[ImaginaryI]", " ", "/", "N"}]}]]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"prckanje", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         SuperscriptBox["w", 
          RowBox[{"-", "k"}]], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", 
           RowBox[{
            RowBox[{"N", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"sodi", "+", 
         RowBox[{"prckanje", " ", "lihi"}]}], ",", 
        RowBox[{"sodi", "-", 
         RowBox[{"prckanje", " ", "lihi"}]}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}], "/", "2"}]}]}], "Input",
 CellChangeTimes->{{3.98229561540228*^9, 3.9822957719467287`*^9}, {
   3.982297086650859*^9, 3.982297110732885*^9}, {3.982297192435114*^9, 
   3.982297199266368*^9}, {3.9822972349613047`*^9, 3.9822972495604353`*^9}, 
   3.982300406590602*^9, {3.982993985828102*^9, 3.9829939929032288`*^9}, {
   3.982994096029237*^9, 3.9829941236328583`*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"e1f04a7c-afc5-4098-a39b-d55c8e90d657"],

