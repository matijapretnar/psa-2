a82172496d64"],

Cell[BoxData[
 RowBox[{
  RowBox[{"lestvica", "[", "t_", "]"}], ":=", 
  RowBox[{"Piecewise", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"c", "[", "t", "]"}], ",", 
       RowBox[{"t", "<", 
        RowBox[{"1", "/", "3"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"e", "[", "t", "]"}], ",", 
       RowBox[{
        RowBox[{"1", "/", "3"}], "<=", "t", "<", 
        RowBox[{"2", "/", "3"}]}]}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       RowBox[{"g", "[", "t", "]"}], ",", "True"}], "}"}]}], "}"}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9829874679635553`*^9, 3.9829874865792503`*^9}},
 CellLabel->
  "In[161]:=",ExpressionUUID->"16418036-5446-4d88-b6c3-f3f72acfc120"],

