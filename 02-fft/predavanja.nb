Cell[BoxData[{
 RowBox[{
  RowBox[{"intt", "[", 
   RowBox[{
    RowBox[{"{", "x_", "}"}], ",", "_"}], "]"}], ":=", 
  RowBox[{"{", "x", "}"}]}], "\n", 
 RowBox[{
  RowBox[{"intt", "[", 
   RowBox[{"koeficienti_", ",", "p_"}], "]"}], ":=", 
  RowBox[{"Mod", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"PowerMod", "[", 
      RowBox[{"2", ",", 
       RowBox[{"-", "1"}], ",", "p"}], "]"}], "*", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"N", "=", 
          RowBox[{"Length", "[", "koeficienti", "]"}]}], ",", "sodi", ",", 
         "lihi", ",", "w", ",", "prckanje"}], "}"}], ",", 
       "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"sodi", "=", 
         RowBox[{"intt", "[", 
          RowBox[{
           RowBox[{"koeficienti", "[", 
            RowBox[{"[", 
             RowBox[{"1", ";;", "N", ";;", "2"}], "]"}], "]"}], ",", "p"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"lihi", "=", 
         RowBox[{"intt", "[", 
          RowBox[{
           RowBox[{"koeficienti", "[", 
            RowBox[{"[", 
             RowBox[{"2", ";;", "N", ";;", "2"}], "]"}], "]"}], ",", "p"}], 
          "]"}]}], ";", "\[IndentingNewLine]", 
        RowBox[{"w", "=", 
         RowBox[{"PowerMod", "[", 
          RowBox[{
           RowBox[{"PrimitiveRoot", "[", "p", "]"}], ",", 
           RowBox[{
            RowBox[{"(", 
             RowBox[{"p", "-", "1"}], ")"}], "/", "N"}], ",", "p"}], "]"}]}], 
        ";", "\[IndentingNewLine]", 
        RowBox[{"prckanje", "=", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"PowerMod", "[", 
            RowBox[{"w", ",", 
             RowBox[{"-", "k"}], ",", "p"}], "]"}], ",", 
           RowBox[{"{", 
            RowBox[{"k", ",", "0", ",", 
             RowBox[{
              RowBox[{"N", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"Join", "[", 
         RowBox[{
          RowBox[{"sodi", "+", 
           RowBox[{"prckanje", " ", "lihi"}]}], ",", 
          RowBox[{"sodi", "-", 
           RowBox[{"prckanje", " ", "lihi"}]}]}], "]"}]}]}], 
      "\[IndentingNewLine]", "]"}]}], ",", "p"}], "]"}]}]}], "Input",
