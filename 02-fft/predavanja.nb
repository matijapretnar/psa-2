Cell[CellGroupData[{

Cell["Hitra Fourierova transformacija", "Section",
 CellChangeTimes->{{3.982292700586426*^9, 3.982292706269356*^9}, {
  3.9822947937790728`*^9, 
  3.982294804471773*^9}},ExpressionUUID->"bdc9187a-7e09-497f-8240-\
ab9c09949713"],

Cell[TextData[{
 "Prednost predstavitve z vrednostmi je, da si lahko to\[CHacek]ke ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["x", "0"], ",", 
    SubscriptBox["x", "1"], ",", "\[Ellipsis]", ",", 
    SubscriptBox["x", "n"]}], TraditionalForm]],ExpressionUUID->
  "5bb4ff82-1904-49d3-b719-fea2d341e70b"],
 " izberemo poljubno. Na primer, ker velja ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "x", ")"}], " ", "=", " ", 
    RowBox[{
     RowBox[{
      SubscriptBox["a", "0"], "+", 
      RowBox[{
       SubscriptBox["a", "1"], "x"}], "+", "\[CenterEllipsis]", " ", "+", " ", 
      RowBox[{
       SubscriptBox["a", "n"], 
       SuperscriptBox["x", "n"]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         SubscriptBox["a", "0"], "+", 
         RowBox[{
          SubscriptBox["a", "2"], 
          SuperscriptBox["x", "2"]}], "+", "\[CenterEllipsis]"}], ")"}], "+", 
       
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          SubscriptBox["a", "1"], "+", 
          RowBox[{
           SubscriptBox["a", "3"], 
           SuperscriptBox["x", "2"]}], "+", "\[CenterEllipsis]"}], ")"}], 
        "x"}]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["p", "s"], "(", 
        SuperscriptBox["x", "2"], ")"}], "+", 
       RowBox[{"x", " ", 
        RowBox[{
         SubscriptBox["p", "l"], "(", 
         SuperscriptBox["x", "2"], ")"}]}]}]}]}]}], TraditionalForm]],
  ExpressionUUID->"2d820f63-e203-4d09-845c-27f3aafcdc8d"],
 " lahko vrednost polinoma ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "8f06101f-b900-497f-99b1-4b05b130af86"],
 " v to\[CHacek]ki ",
 Cell[BoxData[
  FormBox["x", TraditionalForm]],ExpressionUUID->
  "56eb64f7-62aa-4dc9-a8d0-2871f1020734"],
 " prevedemo na iskanje vrednosti dveh manj\[SHacek]ih polinomov v \
to\[CHacek]ki ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["x", "2"], TraditionalForm]],ExpressionUUID->
  "3a73ce6b-7c84-4746-b486-c4e23ef1a7d1"],
 ". Ker je ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["x", "2"], "=", 
    SuperscriptBox[
     RowBox[{"(", 
      RowBox[{"-", "x"}], ")"}], "2"]}], TraditionalForm]],ExpressionUUID->
  "5f1fd75e-78ca-4459-afc8-e81c87e751e2"],
 " na ta na\[CHacek]in enostavno izra\[CHacek]unamo vrednost polinoma v dveh \
to\[CHacek]kah: \n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "1", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "s"], "(", "1", ")"}], "+", 
     RowBox[{
      SubscriptBox["p", "l"], "(", "1", ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     RowBox[{"-", "1"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "s"], "(", "1", ")"}], "-", " ", 
     RowBox[{
      SubscriptBox["p", "l"], "(", "1", ")"}]}]}], TraditionalForm]}],
  ExpressionUUID->"37d8f5eb-517d-4ce5-9a76-46bcaa973da9"],
 "\nLahko bi izbrali tudi\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"p", "(", "\[ImaginaryI]", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "s"], "(", 
      RowBox[{"-", "1"}], ")"}], "+", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{
       SubscriptBox["p", "l"], "(", 
       RowBox[{"-", "1"}], ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     RowBox[{"-", "\[ImaginaryI]"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "s"], "(", 
      RowBox[{"-", "1"}], ")"}], "-", " ", 
     RowBox[{"\[ImaginaryI]", " ", 
      RowBox[{
       SubscriptBox["p", "l"], "(", 
       RowBox[{"-", "1"}], ")"}]}]}]}], TraditionalForm]}],ExpressionUUID->
  "5806d486-daad-4c05-969a-890ba6c4787b"],
 "\ns \[CHacek]imer bi izra\[CHacek]un ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]],ExpressionUUID->
  "2e9692a5-c7b4-4491-991e-e97ab48aebf8"],
 " v 4 to\[CHacek]kah prevedli na izra\[CHacek]un ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "s"], TraditionalForm]],ExpressionUUID->
  "93380d76-b379-42c9-93a2-5777440fc9bb"],
 " in ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["p", "l"], TraditionalForm]],ExpressionUUID->
  "96c323c2-709a-41bf-8b39-75c9a6cf4dae"],
 " v ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],ExpressionUUID->
  "64435715-8dd3-4696-add5-1c5578b5e8de"],
 " in ",
 Cell[BoxData[
  FormBox[
   RowBox[{"-", "1"}], TraditionalForm]],ExpressionUUID->
  "0ee66f94-f9a5-401c-b053-1b74f570a691"],
 ", kar bi nadalje lahko prevedli na:\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["p", "s"], "(", "1", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "ss"], "(", "1", ")"}], "+", 
     RowBox[{
      SubscriptBox["p", "sl"], "(", "1", ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["p", "s"], "(", 
     RowBox[{"-", "1"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "ss"], "(", "1", ")"}], "-", 
     RowBox[{
      SubscriptBox["p", "sl"], "(", "1", ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["p", "l"], "(", "1", ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "ls"], "(", "1", ")"}], "+", 
     RowBox[{
      SubscriptBox["p", "ll"], "(", "1", ")"}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{
     SubscriptBox["p", "l"], "(", 
     RowBox[{"-", "1"}], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "ls"], "(", "1", ")"}], "+", 
     RowBox[{
      SubscriptBox["p", "ll"], "(", "1", ")"}]}]}], TraditionalForm]}],
  ExpressionUUID->"acd71cad-b791-41b4-98c9-4bc20c28f9f0"],
 "\nTorej izra\[CHacek]un ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["p", "ss"], ",", 
    SubscriptBox["p", "sl"], ",", 
    SubscriptBox["p", "ls"], ",", 
    SubscriptBox["p", "ll"]}], TraditionalForm]],ExpressionUUID->
  "0c9769e6-8e4e-4470-85a1-5332ac95146e"],
 " v to\[CHacek]ki ",
 Cell[BoxData[
  FormBox["1", TraditionalForm]],ExpressionUUID->
  "7e481a15-d980-41b7-ab34-713a5963a37d"],
 ".\n\[CapitalCHacek]e je ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Omega]", "=", 
    SuperscriptBox["\[ExponentialE]", 
     RowBox[{"2", "\[Pi]", " ", 
      RowBox[{"\[ImaginaryI]", "/", "N"}]}]]}], TraditionalForm]],
  ExpressionUUID->"41baa787-2f27-4afa-b6fc-c4ec84bae1a0"],
 " ",
 Cell[BoxData[
  FormBox["N", TraditionalForm]],ExpressionUUID->
  "ee386079-e600-4579-a7d6-776076ffce6f"],
 "-ti koren enote, za ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "<", 
    RowBox[{"N", "/", "2"}]}], TraditionalForm]],ExpressionUUID->
  "8a2c0338-cf93-43d8-9ef9-6a67a285f6bb"],
 " velja:\n",
 Cell[BoxData[{
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     SuperscriptBox["\[Omega]", "k"], ")"}], "=", 
    RowBox[{
     RowBox[{
      SubscriptBox["p", "s"], "(", 
      SuperscriptBox["\[Omega]", 
       RowBox[{"2", "k"}]], ")"}], "+", 
     RowBox[{
      SuperscriptBox["\[Omega]", "k"], 
      RowBox[{
       SubscriptBox["p", "l"], "(", 
       SuperscriptBox["\[Omega]", 
        RowBox[{"2", "k"}]], ")"}]}]}]}], TraditionalForm], "\[IndentingNewLine]", 
  FormBox[
   RowBox[{
    RowBox[{"p", "(", 
     SuperscriptBox["\[Omega]", 
      RowBox[{
       RowBox[{"N", "/", "2"}], "+", "k"}]], ")"}], "=", 
    RowBox[{
     RowBox[{
      RowBox[{
       SubscriptBox["p", "s"], "(", 
       SuperscriptBox["\[Omega]", 
        RowBox[{"2", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"N", "/", "2"}], "+", "k"}], ")"}]}]], ")"}], "+", 
      RowBox[{
       SuperscriptBox["\[Omega]", 
        RowBox[{
         RowBox[{"N", "/", "2"}], "+", "k"}]], 
       RowBox[{
        SubscriptBox["p", "l"], "(", 
        SuperscriptBox["\[Omega]", 
         RowBox[{"2", 
          RowBox[{"(", 
           RowBox[{
            RowBox[{"N", "/", "2"}], "+", "k"}], ")"}]}]], ")"}]}]}], "=", 
     RowBox[{
      RowBox[{
       RowBox[{
        SubscriptBox["p", "s"], "(", 
        SuperscriptBox["\[Omega]", 
         RowBox[{"N", "+", 
          RowBox[{"2", "k"}]}]], ")"}], "+", 
       RowBox[{
        SuperscriptBox["\[Omega]", 
         RowBox[{
          RowBox[{"N", "/", "2"}], "+", "k"}]], 
        RowBox[{
         SubscriptBox["p", "l"], "(", 
         SuperscriptBox["\[Omega]", 
          RowBox[{"N", "+", 
           RowBox[{"2", "k"}]}]], ")"}]}]}], "=", 
      RowBox[{
       RowBox[{
        SubscriptBox["p", "s"], "(", 
        SuperscriptBox["\[Omega]", 
         RowBox[{"2", "k"}]], ")"}], "+", 
       RowBox[{
        SuperscriptBox["\[Omega]", 
         RowBox[{
          RowBox[{"N", "/", "2"}], "+", "k"}]], 
        RowBox[{
         SubscriptBox["p", "l"], "(", 
         SuperscriptBox["\[Omega]", 
          RowBox[{"2", "k"}]], ")"}]}]}]}]}]}], TraditionalForm]}],
  ExpressionUUID->"75b63e5a-3b1c-447e-a19e-eb6fa018e372"],
 "\nFaktorjem ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Omega]", "0"], ",", 
    SuperscriptBox["\[Omega]", "1"], ",", "\[Ellipsis]"}], TraditionalForm]],
  ExpressionUUID->"617e2e0e-1543-46a7-8ada-778a98a963e8"],
 ", ki nastopajo pri drugem \[CHacek]lenu, pravimo faktorji pr\[CHacek]kanja \
(",
 StyleBox["twiddle factors",
  FontSlant->"Italic"],
 ").\nTo nas privede do rekurzivne definicije:"
}], "Text",
 CellChangeTimes->{{3.982292707606942*^9, 3.982292717459772*^9}, {
  3.982292772501544*^9, 3.9822927915248327`*^9}, {3.982292845676983*^9, 
  3.9822928595655937`*^9}, {3.9822929713500032`*^9, 3.982292974086001*^9}, {
  3.982293144342763*^9, 3.982293146344493*^9}, {3.982293344641296*^9, 
  3.982293415245414*^9}, {3.982293452625887*^9, 3.98229353415475*^9}, {
  3.982294648281279*^9, 3.9822947667308083`*^9}, {3.9822948135293016`*^9, 
  3.982294883529632*^9}, {3.982295053860841*^9, 3.98229552708777*^9}, {
  3.982295621184682*^9, 3.9822956287501717`*^9}, {3.9822959886170053`*^9, 
  3.982296455037684*^9}},ExpressionUUID->"814bff6b-244d-4d73-a236-\
38ca89f9472f"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"fft", "[", 
   RowBox[{"{", "x_", "}"}], "]"}], ":=", 
  RowBox[{"{", "x", "}"}]}], "\n", 
 RowBox[{
  RowBox[{"fft", "[", "koeficienti_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"N", "=", 
       RowBox[{"Length", "[", "koeficienti", "]"}]}], ",", "sodi", ",", 
      "lihi", ",", "prckanje"}], "}"}], ",", 
    RowBox[{
     RowBox[{"sodi", "=", 
      RowBox[{"fft", "[", 
       RowBox[{"koeficienti", "[", 
        RowBox[{"[", 
         RowBox[{"1", ";;", "N", ";;", "2"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"lihi", "=", 
      RowBox[{"fft", "[", 
       RowBox[{"koeficienti", "[", 
        RowBox[{"[", 
         RowBox[{"2", ";;", "N", ";;", "2"}], "]"}], "]"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"prckanje", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         RowBox[{"2", "\[Pi]", " ", "\[ImaginaryI]", " ", 
          RowBox[{"k", " ", "/", "N"}]}]], ",", 
        RowBox[{"{", 
         RowBox[{"k", ",", "0", ",", 
          RowBox[{
           RowBox[{"N", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Join", "[", 
      RowBox[{
       RowBox[{"sodi", "+", 
        RowBox[{"prckanje", " ", "lihi"}]}], ",", 
       RowBox[{"sodi", "-", 
        RowBox[{"prckanje", " ", "lihi"}]}]}], "]"}]}]}], 
   "\[IndentingNewLine]", "]"}]}]}], "Input",
 CellChangeTimes->{{3.98229561540228*^9, 3.9822957719467287`*^9}},
 CellLabel->"In[11]:=",ExpressionUUID->"2645823e-ce1e-4d57-a228-23765818495c"],

