  RowBox[{"ifft", "[", 
   RowBox[{"{", "x_", "}"}], "]"}], ":=", 
  RowBox[{"{", "x", "}"}]}], "\n", 
 RowBox[{
  RowBox[{"ifft", "[", "koeficienti_", "]"}], ":=", 
  RowBox[{
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"N", "=", 
        RowBox[{"Length", "[", "koeficienti", "]"}]}], ",", "sodi", ",", 
       "lihi", ",", "prckanje"}], "}"}], ",", 
     RowBox[{
      RowBox[{"sodi", "=", 
       RowBox[{"ifft", "[", 
        RowBox[{"koeficienti", "[", 
         RowBox[{"[", 
          RowBox[{"1", ";;", "N", ";;", "2"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"lihi", "=", 
       RowBox[{"ifft", "[", 
        RowBox[{"koeficienti", "[", 
         RowBox[{"[", 
          RowBox[{"2", ";;", "N", ";;", "2"}], "]"}], "]"}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"prckanje", "=", 
       RowBox[{"Table", "[", 
        RowBox[{
         SuperscriptBox["\[ExponentialE]", 
          RowBox[{
           RowBox[{"-", "2"}], "\[Pi]", " ", "\[ImaginaryI]", " ", 
           RowBox[{"k", " ", "/", "N"}]}]], ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "0", ",", 
           RowBox[{
            RowBox[{"N", "/", "2"}], "-", "1"}]}], "}"}]}], "]"}]}], ";", 
      "\[IndentingNewLine]", 
      RowBox[{"Join", "[", 
       RowBox[{
        RowBox[{"sodi", "+", 
         RowBox[{"prckanje", " ", "lihi"}]}], ",", 
        RowBox[{"sodi", "-", 
         RowBox[{"prckanje", " ", "lihi"}]}]}], "]"}]}]}], 
    "\[IndentingNewLine]", "]"}], "/", "2"}]}]}], "Input",
